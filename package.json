  "private": true,
  "description": "Python code compiler",
  "license": "ISC",
  "author": "Chandrakant Singh Danu",
  "main": "index.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "build:prod": "REACT_APP_BACKEND_URL=$REACT_APP_BACKEND_URL npm run build",
    "serve": "serve -s build",
